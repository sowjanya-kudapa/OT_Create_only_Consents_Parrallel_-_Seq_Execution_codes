# ======================================================
# DYNAMODB — COUNTRY EXISTENCE CHECK
# ======================================================
def validate_country_exists(cs_country: str) -> None:
    if not cs_country or not cs_country.strip():
        raise ValueError("cs_country is missing or empty.")
    val_upper = cs_country.strip().upper()
    logger.info("Validating country='%s'", val_upper)
    try:
        resp = country_table.get_item(Key={"country3code": val_upper})
    except ClientError as e:
        raise RuntimeError(f"DynamoDB error [{e.response['Error']['Code']}]: {e}") from e
    if not resp.get("Item"):
        raise ValueError(f"Country '{cs_country}' not found in {COUNTRY_TABLE}. Please provide a valid 3-letter country code.")
    logger.info("Country '%s' is valid", val_upper)


# ======================================================
# DYNAMODB — PURPOSE LOOKUP
# ======================================================
def get_purpose_id(purpose_name: str) -> str:
    try:
        resp = purpose_table.get_item(Key={"Purpose_Name": purpose_name})
        item = resp.get("Item")
        if not item or "Purpose_ID" not in item:
            raise RuntimeError(f"Purpose '{purpose_name}' not found in {PURPOSE_TABLE}.")
        return item["Purpose_ID"]
    except ClientError as e:
        raise RuntimeError(f"DynamoDB error [{e.response['Error']['Code']}]: {e}") from e


# ======================================================
# DYNAMODB — PREFERENCE (SUBSCRIPTION) LOOKUP
# ======================================================
def get_preference_item(unique_subscription_id: str) -> dict:
    try:
        resp = pref_table.get_item(Key={"UniqueSubcriptionID": unique_subscription_id})
        item = resp.get("Item")
        if not item:
            raise RuntimeError(f"Subscription '{unique_subscription_id}' not found in {PREFERENCE_TABLE}.")
        return item
    except ClientError as e:
        raise RuntimeError(f"DynamoDB error [{e.response['Error']['Code']}]: {e}") from e


# ======================================================
# DYNAMODB — COUNTRY CODE LOOKUP (3-letter -> 2-letter)
# ======================================================
def get_country2code(cs_country: str) -> str:
    if not cs_country or not cs_country.strip():
        raise ValueError("cs_country is missing or empty.")
    val_upper = cs_country.strip().upper()
    try:
        resp = country_table.get_item(Key={"country3code": val_upper})
        item = resp.get("Item")
        if item:
            country2code = item["country2code"].upper()
            logger.info("Country code: '%s' -> '%s'", val_upper, country2code)
            return country2code
    except ClientError as e:
        raise RuntimeError(f"DynamoDB error [{e.response['Error']['Code']}]: {e}") from e
    raise ValueError(f"Country '{cs_country}' not found in {COUNTRY_TABLE}. Please provide a valid 3-letter country code.")


# ======================================================
# PRE-FLIGHT VALIDATION
#
# Checks cs_consents and cs_subscriptions before any API call.
# Only logs warnings for skipped entries.
# Logs one summary line at the end with counts.
#
# Consent checks:
#   1. identifier   : non-empty string
#   2. consent      : must be boolean
#   3. signatureDate: must be a valid date
#
# Subscription checks:
#   1. identifier : non-empty string
#   2. optIn      : must be boolean
#   3. optInDate  : normalised if valid; flagged for resolution if not
#
# Returns (valid_consents, valid_subscriptions, skipped_items)
# ======================================================
def preflight_validate(cs_consents: list, cs_subscriptions: list) -> tuple:
    valid_consents      = []
    valid_subscriptions = []
    skipped_items       = []

    # ── Validate cs_consents ─────────────────────────────────────────────────
    for idx, consent in enumerate(cs_consents):
        identifier    = consent.get("identifier")
        consent_val   = consent.get("consent")
        signature_raw = consent.get("signatureDate", "")
        pos           = f"cs_consents[{idx}]"

        if not identifier or not isinstance(identifier, str) or not identifier.strip():
            logger.warning("SKIPPED %s | reason: identifier is missing or empty", pos)
            skipped_items.append({
                "type": "consent", "position": pos,
                "identifier": identifier, "reason": "identifier is missing or empty",
            })
            continue

        if not isinstance(consent_val, bool):
            logger.warning("SKIPPED %s | identifier='%s' | reason: consent must be true/false, got '%s'",
                           pos, identifier, consent_val)
            skipped_items.append({
                "type": "consent", "position": pos, "identifier": identifier,
                "reason": f"consent must be true/false, got type='{type(consent_val).__name__}' value='{consent_val}'",
            })
            continue

        normalized_date = _normalize_and_validate_date(signature_raw)
        if not normalized_date:
            logger.warning("SKIPPED %s | identifier='%s' | reason: signatureDate='%s' is invalid",
                           pos, identifier, signature_raw)
            skipped_items.append({
                "type": "consent", "position": pos,
                "identifier": identifier, "signatureDate": signature_raw,
                "reason": f"signatureDate='{signature_raw}' is invalid (expected YYYY-MM-DDTHH:MM:SS)",
            })
            continue

        consent["signatureDate"] = normalized_date
        valid_consents.append(consent)

    # ── Validate cs_subscriptions ─────────────────────────────────────────────
    for idx, sub in enumerate(cs_subscriptions):
        identifier  = sub.get("identifier")
        opt_in      = sub.get("optIn")
        opt_in_date = sub.get("optInDate", "")
        pos         = f"cs_subscriptions[{idx}]"

        if not identifier or not isinstance(identifier, str) or not identifier.strip():
            logger.warning("SKIPPED %s | reason: identifier is missing or empty", pos)
            skipped_items.append({
                "type": "subscription", "position": pos,
                "identifier": identifier, "reason": "identifier is missing or empty",
            })
            continue

        if not isinstance(opt_in, bool):
            logger.warning("SKIPPED %s | identifier='%s' | reason: optIn must be true/false, got '%s'",
                           pos, identifier, opt_in)
            skipped_items.append({
                "type": "subscription", "position": pos, "identifier": identifier,
                "reason": f"optIn must be true/false, got type='{type(opt_in).__name__}' value='{opt_in}'",
            })
            continue

        normalized_date = _normalize_and_validate_date(opt_in_date)
        if not normalized_date:
            logger.warning("INVALID_DATE %s | identifier='%s' | optInDate='%s' is invalid, will resolve later",
                           pos, identifier, opt_in_date)
            sub["_normalized_optInDate"]  = ""
            sub["_optInDate_was_invalid"] = True
            sub["_optInDate_raw"]         = opt_in_date
        else:
            sub["_normalized_optInDate"]  = normalized_date
            sub["_optInDate_was_invalid"] = False

        valid_subscriptions.append(sub)

    logger.info("Preflight done | consents=%d | subscriptions=%d | skipped=%d",
                len(valid_consents),
                len(valid_subscriptions),
                len(skipped_items))

    return valid_consents, valid_subscriptions, skipped_items


# ======================================================
# SUBSCRIPTION DATE RESOLUTION
#
# Walk subscriptions in payload order (top to bottom).
# First entry where ALL of the following are true:
#   1. identifier is a non-empty string
#   2. optIn is True  (not false)
#   3. optInDate is valid
#   4. subscription exists in DynamoDB for this country
#      (country_code + identifier found in preference table)
# -> use that optInDate as interactionDate for ALL subscriptions.
# No sorting — payload order wins.
#
# If no such entry found -> use today's UTC date.
# ======================================================
def _resolve_subscription_dates(
    valid_subscriptions: list,
    country_code: str,
    skipped_items: list,
) -> tuple:

    # Step 1: find first valid optInDate in payload order
    # All 4 conditions: identifier + optIn=True + valid date + exists in DB
    global_first_date = None
    for sub in valid_subscriptions:
        identifier = sub.get("identifier", "")
        opt_in     = sub.get("optIn")
        norm_date  = sub.get("_normalized_optInDate", "")

        identifier_ok = bool(identifier and isinstance(identifier, str) and identifier.strip())
        optin_ok      = opt_in is True   # must be True, not false
        date_ok       = bool(norm_date)

        if not (identifier_ok and optin_ok and date_ok):
            reasons = []
            if not identifier_ok: reasons.append("identifier invalid")
            if not optin_ok:      reasons.append(f"optIn is not True (got {opt_in})")
            if not date_ok:       reasons.append("optInDate invalid")
            logger.warning("Skipping for date selection | identifier='%s' | reasons: %s",
                           identifier, ", ".join(reasons))
            continue

        # Check subscription exists in preference table for this country
        unique_id = f"{country_code}_{identifier.strip()}"
        try:
            get_preference_item(unique_id)
            global_first_date = norm_date
            logger.info("First valid optInDate found | identifier='%s' | country_key='%s' | optIn=True | date='%s' | will use for all subscriptions",
                        identifier.strip(), unique_id, norm_date)
            break
        except RuntimeError:
            logger.warning("Skipping for date selection | identifier='%s' | reason: not found in preference table for country='%s'",
                           identifier.strip(), country_code)

    # Step 2: fall back to today if no valid date found
    if not global_first_date:
        global_first_date = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S")
        logger.warning("No valid optInDate with optIn=True found | using today's date='%s' for all subscriptions",
                       global_first_date)
    else:
        logger.info("interactionDate='%s' will be applied to all %d subscription(s)",
                    global_first_date, len(valid_subscriptions))

    # Step 3: stamp every subscription with the resolved date
    resolved = []
    for sub in valid_subscriptions:
        identifier    = sub.get("identifier", "").strip()
        original_date = sub.get("_normalized_optInDate") or sub.get("_optInDate_raw", "")
        if original_date != global_first_date:
            logger.info("Subscription '%s' | own date='%s' -> overridden to '%s'",
                        identifier, original_date, global_first_date)
        sub["_normalized_optInDate"] = global_first_date
        resolved.append(sub)

    logger.info("All %d subscription(s) assigned interactionDate='%s'",
                len(resolved), global_first_date)
    return resolved, skipped_items


