def fetch_data_subject_by_uuid(access_token: str, ot_uuid: str) -> dict:
    call_num = _log_api_call("PROFILES_URL_fetch_uuid")
    logger.info("Fetching profile by UUID='%s' | call=%d", ot_uuid, call_num)
    resp = session.get(
        PROFILES_URL,
        params={"identifier": ot_uuid},
        headers={"Authorization": f"Bearer {access_token}"},
        verify=SSL_VERIFY,
        timeout=REQUEST_TIMEOUT,
    )
    logger.info("Fetch by UUID response | status=%d | call=%d", resp.status_code, call_num)
    if not resp.ok:
        raise RuntimeError(f"Data subject fetch by UUID HTTP {resp.status_code}: {resp.text}")
    content = resp.json().get("content", [])
    if not content:
        logger.warning("No profile found for UUID='%s'", ot_uuid)
        return {}
    logger.info("Profile fetched successfully for UUID='%s'", ot_uuid)
    return content[0]


